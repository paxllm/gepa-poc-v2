# NVIDIA NIM Configuration
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# LLM rate limiting (use LLM_MAX_PARALLEL=1 for ~40 RPM NVIDIA keys)
LLM_MAX_RPM=35
LLM_MAX_PARALLEL=1
LLM_RETRY_MAX=6
# Per-request timeout in seconds (use 300+ for reasoning models like Nemotron)
LLM_TIMEOUT_SECONDS=300

# Demo mode: use wizard prompts directly as GEPA seed (skip LLM seed generation)
DEMO_MODE=false

# Hiring Configuration
HIRE_THRESHOLD=3.0

# GEPA Configuration
GEPA_MAX_METRIC_CALLS=150

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/resume_gepa.db

# Upload directory
UPLOAD_DIR=./data/uploads
